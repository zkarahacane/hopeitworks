# =============================================================================
# Application Configuration
# =============================================================================

# Application environment: development, staging, production
APP_ENV=development

# =============================================================================
# Server Configuration
# =============================================================================

# Port the API server listens on
SERVER_PORT=8080

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL host (use "postgres" for docker-compose, "localhost" for local dev)
DB_HOST=localhost

# PostgreSQL port
DB_PORT=5432

# Database name
DB_NAME=hopeitworks_dev

# Database user
DB_USER=hopeitworks

# Database password
DB_PASSWORD=hopeitworks_dev_password

# SSL mode: disable (local dev), require (production)
DB_SSLMODE=disable

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=debug
